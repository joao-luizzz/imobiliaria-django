# ──────────────────────────────────────────────────────────────────────────────
# VARIÁVEIS DE AMBIENTE — Imobiliária Django
# Copie este arquivo para .env e preencha os valores.
# O arquivo .env nunca deve ser commitado no repositório.
# ──────────────────────────────────────────────────────────────────────────────


# ── Obrigatórias ──────────────────────────────────────────────────────────────

# Chave secreta do Django. Gere uma nova com:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=troque-por-uma-chave-gerada-acima

# True apenas em desenvolvimento local. NUNCA True em produção.
DEBUG=True

# Hosts permitidos separados por vírgula.
# Dev:  127.0.0.1,localhost
# Prod: seudominio.com,www.seudominio.com
ALLOWED_HOSTS=127.0.0.1,localhost


# ── Banco de dados ────────────────────────────────────────────────────────────

# Sem esta variável o Django usa SQLite (só recomendado em dev).
# Para produção com PostgreSQL, descomente e preencha:
# DATABASE_URL=postgres://USUARIO:SENHA@HOST:5432/NOME_DO_BANCO

# Exemplos prontos:
#   Railway:  fornecido automaticamente, basta copiar da dashboard
#   Render:   fornecido automaticamente, basta copiar da dashboard
#   VPS:      postgres://imobiliaria:senha_aqui@localhost:5432/imobiliaria_db


# ── Segurança (produção com HTTPS) ────────────────────────────────────────────
# Deixe comentado em dev. Descomente TODOS ao ir para produção com SSL.

# SECURE_SSL_REDIRECT=True
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True
# SECURE_HSTS_SECONDS=31536000
# SECURE_HSTS_INCLUDE_SUBDOMAINS=True
# SECURE_HSTS_PRELOAD=True
